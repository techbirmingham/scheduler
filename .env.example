# Copy this file to .env and fill in the real values.
# .env is gitignored — never commit real credentials.

# Supabase — from your project's API settings (Project Settings > API)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Mapbox — from https://account.mapbox.com/access-tokens/
# Restrict this token to your deployment domain(s) in the Mapbox dashboard.
VITE_MAPBOX_TOKEN=pk.your-mapbox-public-token
